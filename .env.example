# RAG-Time — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs
# IMPORTANT : ne jamais committer .env dans Git

# ── Clés API ──────────────────────────────────────────────────────────────────

# OpenRouter — accès aux LLM (gpt-4o-mini, llama-3, etc.)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HuggingFace — accès aux embeddings via Inference API (plan gratuit disponible)
# https://huggingface.co/settings/tokens
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Modèles ───────────────────────────────────────────────────────────────────

# Modèle d'embedding (HuggingFace Inference API ou local via SentenceTransformer)
# Options : sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 (384 dims, gratuit HF)
#           BAAI/bge-m3 (1024 dims, local, haute performance)
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Modèle LLM par défaut (via OpenRouter)
# Options : openai/gpt-4o-mini | openai/gpt-4o | meta-llama/llama-3.3-70b-instruct:free
LLM_MODEL=openai/gpt-4o-mini

# Modèle utilisé comme juge pour l'évaluation LLM-as-judge
JUDGE_MODEL=openai/gpt-4o-mini

# ── Paramètres RAG ────────────────────────────────────────────────────────────

# Nombre de chunks récupérés par requête (top-K)
TOP_K=5

# Taille des chunks pour les documents uploadés (en caractères)
CHUNK_SIZE=400

# Chevauchement entre chunks consécutifs (en caractères)
CHUNK_OVERLAP=50
